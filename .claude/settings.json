{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(./bin/phpunit)",
      "Bash(docker compose *)",
      "Bash(./bin/phpcs)",
      "Bash(./bin/phpcbf)",
      "Bash(./bin/phpstan)",
      "Bash(./bin/phpstan *)",
      "Bash(./bin/composer *)",
      "Bash(./bin/php-syntax-check *)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git --version)",
      "Bash(git check-attr *)",
      "Skill(sq-git:commit)",
      "Skill(sq-git:open-pr)",
      "Skill(sq-git:sync-branch)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)"
    ],
    "ask": [
      "Bash(./setup.sh:*)",
      "Bash(./teardown.sh:*)",
      "Bash(git push:*)"
    ]
  }
}